{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=TextileMonitoring;User Id=sa;Password=YourPassword123!;TrustServerCertificate=True;"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest",
    "PrefetchCount": 16,
    "RetryCount": 3,
    "RetryIntervalMs": 1000
  },
  "Database": {
    "CommandTimeout": 120,
    "MaxRetryCount": 5,
    "MaxRetryDelaySec": 10,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false
  },
  "RandomForest": {
    "NumberOfTrees": 200,
    "OobErrorMinBps": 65,
    "OobErrorMaxBps": 180,
    "ModelVersion": "rf-voc-v1.0"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "MassTransit": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
