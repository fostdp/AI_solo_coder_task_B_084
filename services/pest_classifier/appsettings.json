{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TextileMonitoring;TrustServerCertificate=True;Integrated Security=True;"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest",
    "PrefetchCount": 32,
    "RetryCount": 3,
    "RetryIntervalMs": 1000
  },
  "Database": {
    "ConnectionString": "Server=localhost;Database=TextileMonitoring;TrustServerCertificate=True;Integrated Security=True;",
    "CommandTimeout": 120,
    "MaxRetryCount": 5,
    "MaxRetryDelaySec": 10,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false
  },
  "CnnClassifier": {
    "ModelVersion": "cnn-frass-v1.0",
    "MinInferenceLatencyMs": 45,
    "MaxInferenceLatencyMs": 95,
    "TemperatureScale": 1.0,
    "NoiseLevel": 0.08,
    "MinInstars": 1,
    "MaxInstars": 5,
    "BasePopulationPerParticle": 0.25
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "MassTransit": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
